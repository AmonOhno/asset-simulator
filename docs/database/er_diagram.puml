@startuml Database ER Diagram
!theme plain

title Asset Simulator - Database Entity Relationship Diagram

' --- Entities ---
entity "users" as users {
  * id : uuid <<PK>>
  --
  * email : string
  --
  created_at : timestamp
}

entity "journal_accounts" as journal_accounts {
  * id : string <<PK>>
  --
  * name : string
  * category : string
  * balance : numeric
  * include_in_summary : boolean
  * user_id : uuid <<FK>>
  --
  created_at : timestamp
  updated_at : timestamp
}

entity "journal_entries" as journal_entries {
  * id : string <<PK>>
  --
  * date : date
  * description : string
  * debit_account_id : string <<FK>>
  * credit_account_id : string <<FK>>
  * amount : numeric
  * user_id : uuid <<FK>>
  --
  created_at : timestamp
  updated_at : timestamp
}

entity "regular_journal_entries" as regular_journal_entries {
  * id : string <<PK>>
  --
  * name : string
  description : string
  * debit_account_id : string <<FK>>
  * credit_account_id : string <<FK>>
  amount : numeric
  * frequency : string
  start_date : date
  end_date : date
  date_of_year : string
  date_of_month : integer
  holiday_div_of_month : string
  mon_flg_of_week : boolean
  tue_flg_of_week : boolean
  wed_flg_of_week : boolean
  thu_flg_of_week : boolean
  fri_flg_of_week : boolean
  sat_flg_of_week : boolean
  sun_flg_of_week : boolean
  public_holiday_ex_flg_of_week : boolean
  last_executed_date : date
  * user_id : uuid <<FK>>
  --
  created_at : timestamp
  updated_at : timestamp
}

entity "schedule_events" as schedule_events {
  * event_id : string <<PK>>
  --
  * title : string
  * all_day_flg : boolean
  * start_date : date
  start_time : string
  * end_date : date
  end_time : string
  description : string
  * user_id : uuid <<FK>>
  --
  created_at : timestamp
}

entity "goals" as goals {
  * id : string <<PK>>
  --
  * account_id : string <<FK>>
  * period : string
  * amount : numeric
  * user_id : uuid <<FK>>
  --
  created_at : timestamp
}

entity "accounts" as accounts {
  * id : string <<PK>>
  --
  * name : string
  * institution : string
  * branch_number : string
  * type : string
  * account_number : string
  * account_holder : string
  * user_id : uuid <<FK>>
}

entity "credit_cards" as credit_cards {
  * id : string <<PK>>
  --
  * name : string
  * closing_day : integer
  * payment_day : integer
  * linked_account_id : string <<FK>>
  * user_id : uuid <<FK>>
}

' --- Relationships ---
users ||--o{ journal_accounts : "user_id"
users ||--o{ journal_entries : "user_id"
users ||--o{ regular_journal_entries : "user_id"
users ||--o{ schedule_events : "user_id"
users ||--o{ accounts : "user_id"
users ||--o{ credit_cards : "user_id"
users ||--o{ goals : "user_id"

accounts ||--o| credit_cards : "linked_account_id"

journal_accounts ||--o{ journal_entries : "debit_account_id"
journal_accounts ||--o{ journal_entries : "credit_account_id"

journal_accounts ||--o{ regular_journal_entries : "debit_account_id"
journal_accounts ||--o{ regular_journal_entries : "credit_account_id"

journal_accounts ||--o{ goals : "account_id"

' --- Notes ---
note top of users
  Supabase Auth の auth.users。
  アプリ側で新規作成する
  テーブルではない。
  他の全テーブルは user_id で
  行レベルセキュリティ(RLS)を
  適用する想定。
end note

note right of journal_entries
  複式簿記の仕訳コアテーブル。
  借方・貸方の両勘定科目を持つ。
  新規作成は RPC
  create_journal_entry 経由
  (残高更新も同時に行う)。
end note

note bottom of regular_journal_entries
  定期取引のテンプレート。
  frequency: daily/weekly/monthly/yearly/free
  holiday_div_of_month は
  'before'/'after'/'none' の文字列。
  last_executed_date で
  同日の重複実行を防止する。
  実行すると journal_entries が
  1件生成される。
end note

note left of journal_accounts
  勘定科目マスタ。
  Categories: Asset, Liability,
  Equity, Revenue, Expense。
  balance は仕訳から更新される。
end note

note bottom of schedule_events
  カレンダー上のスケジュール
  イベント（給料日・支払日等の
  リマインド用）。仕訳とは独立。
end note

note bottom of goals
  勘定科目ごと・期間(日次/月次)ごと
  の支出目標。
  period: 'day'/'month'。
  (user_id, account_id, period) は
  一意制約あり(UI からは既存があれば
  金額を上書き更新)。
end note

note bottom of accounts
  金融口座マスタ。型定義のみ存在し、
  現行 UI からは未使用
  （journal_accounts の
  isSystemAccount 判定で
  "acc_" プレフィックスのみ参照）。
end note

note bottom of credit_cards
  クレジットカードマスタ。型定義のみ
  存在し、現行 UI からは未使用
  （"card_" プレフィックスのみ参照）。
end note

' --- Categories ---
package "Enums" {
  enum AccountCategory {
    Asset
    Liability
    Equity
    Revenue
    Expense
  }

  enum RecurrenceFrequency {
    daily
    weekly
    monthly
    yearly
    free
  }

  enum HolidayDivOfMonth {
    none
    before
    after
  }
}

journal_accounts --> AccountCategory
regular_journal_entries --> RecurrenceFrequency
regular_journal_entries --> HolidayDivOfMonth

' --- Views / RPC (documentation only, not physical tables) ---
note as ViewNote
  VIEW: v_journal_entries_for_calendar
  journal_entries に借方/貸方の
  勘定科目名・カテゴリを JOIN 済み。
  カレンダー表示専用。

  RPC: fn_balance_sheet(p_user_id, p_end_date)
  RPC: fn_profit_loss(p_user_id, p_start_date, p_end_date)
  どちらも user_id, account_id, category,
  name, sum_amount の集計行を返す。
end note

journal_entries .. ViewNote

@enduml
