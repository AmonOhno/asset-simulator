{
  "name": "asset-simulator",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "desktop",
    "packages/*",
    "client"
  ],
  "scripts": {
    "dev": "npm run dev:desktop",
    "dev:desktop": "npx turbo run dev --filter=desktop",
    "build": "npx turbo run build",
    "start": "npm run start:desktop",
    "start:desktop": "npm run start --workspace=desktop",
    "test": "npx turbo run test",
    "lint": "npx turbo run lint",
    "clean": "npx turbo run clean",
    "playground": "cd mobile && npm run dev",
    "storybook": "cd mobile && npm run storybook",
    "dev:client": "cd client && npm run dev",
    "build:client": "cd client && npm run build"
  },
  "dependencies": {
    "turbo": "^2.5.6",
    "crypto": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^16.18.126",
    "turbo": "^2.5.6",
    "typescript": "^4.9.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
  ,
  "overrides": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  }
}
