{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@asset-simulator/shared": ["../packages/shared/src/index.ts"],
      "@web/*": ["../web/src/*"],
      "@mobile/*": ["../web-new/playground/src/*"],
      "@mobile-components/*": ["../web-new/src/components/*"]
    }
  },
  "include": ["src"]
}
